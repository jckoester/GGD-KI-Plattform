    "@sveltejs/vite-plugin-svelte": "^4.0.4",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "jsdom": "^29.1.1",
    "svelte": "^5.55.4",
    "tailwindcss": "^4.2.2",
    "vite": "^5.0.0",
    "vitest": "^2.1.9"
  },
  "dependencies": {
    "chart.js": "^4.5.1",
    "d3-force": "^3.0.0",
    "dompurify": "^3.4.1",
    "highlight.js": "^11.11.1",
    "js-yaml": "^4.1.1",
    "katex": "^0.17.0",
    "lucide-svelte": "^1.0.1",

{
  "name": "ggd-ki-frontend",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "scripts": {
    "generate:taxonomy": "python3 ../scripts/generate_taxonomy.py",
    "prebuild": "npm run generate:taxonomy",
    "dev": "npm run generate:taxonomy && vite dev",
    "build": "vite build",
    "preview": "vite preview",

# Datenbankpasswort: openssl rand -base64 32
POSTGRES_PASSWORD=
DATABASE_URL=postgresql+asyncpg://postgres:<POSTGRES_PASSWORD>@localhost:5432/ggd_ki

# Integrationstests (separate Test-DB mit pgvector)
TEST_DATABASE_URL=postgresql+asyncpg://postgres:<POSTGRES_PASSWORD>@localhost:5432/ggd_ki_test
# SCHOOL_SECRET (HMAC-Pseudonymisierung) und JWT_SECRET (Auth-Cookie-Signatur): in PRODUKTION
# je ein starker Zufallswert ≥ 32 Zeichen (`openssl rand -base64 32`). Platzhalter/leer/zu kurz
# werden beim Start abgelehnt (ENVIRONMENT != development). Lokal dürfen kurze Test-Werte stehen.
SCHOOL_SECRET=           # openssl rand -base64 32
JWT_SECRET=              # openssl rand -base64 32
# LiteLLM-Proxy. Lokal läuft er als Prozess in der backend-venv auf Port 4000
# (siehe docs/dev/dev-setup.md → "LiteLLM lokal starten"), in Produktion im Netz.
LITELLM_PROXY_URL=http://localhost:4000
# Voller Zugriff auf den LiteLLM-Proxy (Key-Minting, Budgets). In PRODUKTION zwingend ein
# starker Zufallswert ≥ 20 Zeichen (`openssl rand -base64 32`); Platzhalter/leer werden beim
# Start abgelehnt (ENVIRONMENT != development). Lokal darf ein schwacher Dev-Key stehen.
# Muss mit master_key in der LiteLLM-Config übereinstimmen.
LITELLM_MASTER_KEY=
# Provider-Key, den der lokale Proxy an OpenAI durchreicht (gpt-4/Embeddings/Bild).
# Nur für den Proxy nötig — das Backend selbst ruft nie direkt einen Provider auf.
OPENAI_API_KEY=
# Self-hosted Fallback via Ollama (Pflicht-Fallback laut Projektvorgabe).
OLLAMA_BASE_URL=http://localhost:11434
# SEPARATE Postgres-DB NUR für den LiteLLM-Proxy (Virtual Keys, Teams, Budgets, SpendLogs).
# Plain postgresql:// (NICHT der asyncpg-DSN von DATABASE_URL) und eigene DB, damit LiteLLMs
# Prisma-Schema nicht mit dem Alembic-Schema der App kollidiert.
LITELLM_DATABASE_URL=postgresql://postgres:<POSTGRES_PASSWORD>@localhost:5432/litellm
# Login der LiteLLM-Admin-UI (http://localhost:4000/ui). Optional: ohne diese Vars ist der
# Login Username `admin` + Passwort = LITELLM_MASTER_KEY. Betrifft NUR die Proxy-UI, nicht
# das GGD-KI-Frontend (das läuft über den yaml_test-Adapter / IServ).
UI_USERNAME=admin
UI_PASSWORD=
CHAT_DEFAULT_MODEL=
TITLE_MODEL=
SPEND_LOG_DELAY=1.0        # Sekunden Wartezeit nach Stream-Ende vor SpendLogs-Abfrage (Default: 1.0)
FRONTEND_ORIGIN=http://localhost:5173
ENVIRONMENT=development
NGINX_PORT=80                # Host-Port für nginx (Default 80; z.B. 8080 hinter vorgelagertem Reverse-Proxy)
AUTH_CONFIG_PATH=config/auth.yaml
BUDGET_TIERS_PATH=config/budget_tiers.yaml
AUTH_ISERV_CLIENT_SECRET=   # nur in Produktion setzen
# Loggt beim Login die komplette SSO-userinfo (Diagnose von Rollen-/Gruppen-Mapping).
# Enthält Klarnamen/E-Mail → nur temporär aktivieren. Siehe docs/admin/konfiguration.md.
AUTH_DEBUG_USERINFO=false
PUBLIC_STUDENT_GRADES=[5,6,7,8,9,10,11,12]  # Jahrgangsstufen (Frontend + Backend)
PUBLIC_PERIODS=[1,2,3,4,5,6,7,8]  # Stundenraster der Schule (Wochenmuster-Editor); ausgelassene Stunden weglassen, z.B. [1,2,3,4,5,6,8]
SCHULART=GYM                 # Schulart dieser Schule (GYM, GMS, RS, HS …)
EXPORT_SCHOOL_NAME=          # Schulname in Curriculum-Exporten (PDF-Kopfzeile + YAML `schule`); leer → Wert aus Curriculum-Metadaten
PUBLIC_SCHOOL_NAME=ki@schule
PUBLIC_SCHOOL_LOGO_URL=          # Fallback für beide Themes; leer → Initialen-Kreis
PUBLIC_SCHOOL_LOGO_URL_LIGHT=   # Logo für helles Theme (überschreibt LOGO_URL)
PUBLIC_SCHOOL_LOGO_URL_DARK=    # Logo für dunkles Theme (überschreibt LOGO_URL)

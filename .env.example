# Datenbankpasswort: openssl rand -base64 32
POSTGRES_PASSWORD=
DATABASE_URL=postgresql+asyncpg://postgres:<POSTGRES_PASSWORD>@localhost:5432/ggd_ki

# Integrationstests (separate Test-DB mit pgvector)
TEST_DATABASE_URL=postgresql+asyncpg://postgres:<POSTGRES_PASSWORD>@localhost:5432/ggd_ki_test
SCHOOL_SECRET=           # openssl rand -base64 32
JWT_SECRET=              # openssl rand -base64 32
LITELLM_PROXY_URL=http://localhost:4000
LITELLM_MASTER_KEY=
CHAT_DEFAULT_MODEL=
TITLE_MODEL=
SPEND_LOG_DELAY=1.0        # Sekunden Wartezeit nach Stream-Ende vor SpendLogs-Abfrage (Default: 1.0)
FRONTEND_ORIGIN=http://localhost:5173
ENVIRONMENT=development
AUTH_CONFIG_PATH=config/auth.yaml
BUDGET_TIERS_PATH=config/budget_tiers.yaml
AUTH_ISERV_CLIENT_SECRET=   # nur in Produktion setzen
PUBLIC_STUDENT_GRADES=[5,6,7,8,9,10,11,12]  # Jahrgangsstufen (Frontend + Backend)
PUBLIC_PERIODS=[1,2,3,4,5,6,7,8]  # Stundenraster der Schule (Wochenmuster-Editor); ausgelassene Stunden weglassen, z.B. [1,2,3,4,5,6,8]
SCHULART=GYM                 # Schulart dieser Schule (GYM, GMS, RS, HS …)
EXPORT_SCHOOL_NAME=          # Schulname in Curriculum-Exporten (PDF-Kopfzeile + YAML `schule`); leer → Wert aus Curriculum-Metadaten
PUBLIC_SCHOOL_NAME=ki@schule
PUBLIC_SCHOOL_LOGO_URL=          # Fallback für beide Themes; leer → Initialen-Kreis
PUBLIC_SCHOOL_LOGO_URL_LIGHT=   # Logo für helles Theme (überschreibt LOGO_URL)
PUBLIC_SCHOOL_LOGO_URL_DARK=    # Logo für dunkles Theme (überschreibt LOGO_URL)

{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["metadata", "config"],
  "additionalProperties": false,
  "properties": {
    "metadata": {
      "type": "object",
      "required": ["name", "audience"],
      "additionalProperties": false,
      "properties": {
        "name":            { "type": "string",  "minLength": 1 },
        "description":     { "type": "string" },
        "subject":         { "type": "string" },
        "grades":          { "type": "array", "items": { "type": "integer", "minimum": 1, "maximum": 13 } },
        "tags":            { "type": "array",  "items": { "type": "string" } },
        "author":          { "type": "string" },
        "license":         { "type": "string" },
        "version":         { "type": "string" },
        "created":         { "type": "string" },
        "updated":         { "type": "string" },
        "audience":        { "type": "string", "enum": ["student", "teacher", "all"] },
        "available_from":  { "type": ["string", "null"] },
        "available_until": { "type": ["string", "null"] }
      }
    },
    "config": {
      "type": "object",
      "required": ["system_prompt", "model"],
      "additionalProperties": false,
      "properties": {
        "model":         { "type": "string", "minLength": 1 },
        "temperature":   { "type": "number", "minimum": 0.0, "maximum": 2.0 },
        "max_tokens":    { "type": "integer", "minimum": 1 },
        "system_prompt": { "type": "string", "minLength": 1 }
      }
    }
  }
}
